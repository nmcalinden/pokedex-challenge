# Base URL for the .NET API (default: http://localhost:5001 when using Docker Compose)
VITE_API_BASE_URL=http://localhost:5001

# Session token for authenticating with the favourites API.
# Sent as: Authorization: Bearer <this-value>
# This is a static, pre-generated token — no login flow is required.
VITE_SESSION_TOKEN=pokedex-challenge-2027-a1b2c3d4-e5f6-7890-abcd-ef1234567890
